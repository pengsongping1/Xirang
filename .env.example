# Choose one provider you actually use:
# anthropic | openai | deepseek | ollama | lmstudio | openrouter | groq | together | fireworks | openai_compat
XIRANG_PROVIDER=ollama
XIRANG_PROFILE=balanced

# -------- Cloud providers --------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XIRANG_OPENROUTER_MODEL=qwen/qwen3-coder:free
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=

# -------- Local providers / OpenAI-compatible endpoints --------
XIRANG_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
XIRANG_OLLAMA_MODEL=qwen2.5-coder:7b
XIRANG_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
XIRANG_LMSTUDIO_MODEL=local-model
OPENAI_COMPAT_API_KEY=
XIRANG_OPENAI_COMPAT_BASE_URL=http://127.0.0.1:8000/v1
XIRANG_OPENAI_COMPAT_MODEL=gpt-4o-mini

# -------- Optional desktop co-pilot --------
# Enables the `desktop` tool for explicit screenshot/mouse/keyboard actions.
# Off by default for safety. Requires: pip install ".[desktop]"
XIRANG_DESKTOP_ENABLE=0
